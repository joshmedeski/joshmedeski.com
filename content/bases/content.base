views:
  - type: table
    name: posts
    filters:
      and:
        - file.folder == "posts"
    order:
      - file.name
      - pubDate
      - category
      - youtubeUrl
      - file.size
    sort:
      - property: pubDate
        direction: DESC
    columnSize:
      note.youtubeUrl: 646
  - type: calendar
    name: Calendar
    order:
      - title
      - category
    startDate: note.pubDate
    weekStartDay: sunday
