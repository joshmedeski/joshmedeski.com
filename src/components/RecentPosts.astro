---
import PostCard from './post/PostCard.astro'
import { getCollection } from 'astro:content'
import Section from './sections/Section.astro'

const includeDrafts = import.meta.env.DEV
const allPosts = await getCollection(
  'posts',
  ({ data: { draft } }) => includeDrafts || !draft,
)
const sortedPosts = allPosts.sort(
  ({ data: a }, { data: b }) => b.pubDate.getTime() - a.pubDate.getTime(),
)
const recentPosts = sortedPosts.slice(0, 4)
---

<Section
  title="Recent Posts"
  viewAllHref="/posts"
  viewAllLabel="View all posts"
>
  <div class="grid items-stretch gap-4 sm:grid-cols-2 sm:gap-8">
    {recentPosts.map((post) => <PostCard post={post} />)}
  </div>
</Section>
