---
import { getEntry } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import PostMeta from './PostMeta.astro'

interface Props {
  post: CollectionEntry<'posts'>
}
const { post } = Astro.props
const category = await getEntry(post.data.category)
---

<div
  class=`relative flex flex-col justify-end rounded-lg px-4 py-4 shadow-md md:px-6 ${category?.data?.style?.themeColor}`
>
  <a
    href={`/posts/${post.id}`}
    class="z-20 grid grow gap-4 md:grid-cols-5 md:gap-6"
    data-astro-prefetch
  >
    <div
      class="flex flex-col justify-end md:col-span-2 md:col-start-4 md:row-start-1"
    >
      <div
        class="relative"
        data-pixelate-render
        data-pixelate-render-trigger="inview"
      >
        {
          post.data.draft && (
            <span class="absolute right-2 top-2 z-30 rounded bg-amber-400 px-2 py-0.5 text-xs font-extrabold uppercase tracking-wider text-black shadow-md">
              Draft
            </span>
          )
        }
        <Image
          src={post.data.heroImage}
          alt={post.data.title}
          width="500"
          height="281.25"
          class="mb-2 aspect-video w-full rounded-lg bg-black shadow-md md:mb-8"
          transition:name={`post-${post.id}-thumb`}
          style={{ backgroundColor: category?.data.style.themeColor }}
          data-pixelate-render-img
        />
      </div>
      <Image
        src={post.data.heroImage}
        alt={post.data.title}
        width="1640"
        height="922.5"
        class="hidden"
      />
    </div>

    <div
      class="md:col-start-0 flex flex-col justify-end md:col-span-3 md:row-start-1"
    >
      <div class="flex grow flex-col justify-center">
        <h3 class="mb-2 mr-4 text-balance text-xl font-extrabold leading-tight">
          {post.data.title}
        </h3>
      </div>

      <p class="-ml-3 mb-12 rounded-t-md bg-black p-3 text-sm text-slate-500">
        {post.data.description}
      </p>
    </div>
  </a>

  <div class="z-10 -mx-6 -mb-4 -mt-20 rounded-b-lg bg-black px-6 pb-2 pt-14">
    <PostMeta post={post} align="left" />
  </div>
</div>

<script>
  import { initPixelateRender } from '../../scripts/pixelateRender'
  document.addEventListener('astro:page-load', initPixelateRender)
</script>
