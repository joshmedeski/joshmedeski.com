---
import { SITE_TITLE } from '../config'
import Link from './Link.astro'
import { MenuIcon } from './icons/index.astro'
import SearchButton from './SearchButton.astro'
import Wrapper from './Wrapper.astro'

export interface Props {
  themeColor?: string
}
const props = Astro.props
---

<div class={`${props.themeColor && props.themeColor}`} data-pagefind-ignore>
  <Wrapper>
    <header class="grid content-center rounded-lg py-4 md:grid-cols-7">
      <div class="align-center col-span-2 flex items-center justify-between">
        <a
          href="/"
          class="mt-1 inline text-2xl font-bold leading-normal"
          data-astro-prefetch
        >
          {SITE_TITLE}
        </a>
        <a href="#menu" class="mt-1 flex items-center md:hidden">
          <MenuIcon class="mr-2 h-6 w-6 text-neutral-800" />
          <span>Menu</span>
        </a>
      </div>

      <nav
        class="col-span-3 hidden w-full items-center justify-center space-x-8 text-lg md:flex"
      >
        <Link href="/posts">Posts</Link>
        <Link href="/videos">Videos</Link>
        <Link href="/projects">Projects</Link>
        <Link href="/guides">Guides</Link>
        <Link href="/about">About</Link>
      </nav>

      <div class="col-span-2 hidden items-center justify-end md:flex">
        <SearchButton />
      </div>
    </header>
  </Wrapper>
</div>
