---
import '../styles/global.css'
import Footer from './LayoutFooter.astro'
import Head from './LayoutHead.astro'
import type { Props as HeadProps } from './LayoutHead.astro'
import Header from './LayoutHeader.astro'
import Search from './Search.astro'
import clsx from 'clsx'

interface Props extends HeadProps {
  hideCta?: boolean
  overlapHeader?: boolean
  noIndex?: boolean
}
const props = Astro.props
---

<!doctype html>
<html lang="en">
  <Head {...props} />
  <body
    class="relative flex min-h-screen flex-col justify-between text-white bg-black"
  >
    <header class="z-20">
      <Header themeColor={props.themeColor} />
    </header>

    <main
      class={clsx(props.overlapHeader && `-mt-[104px] z-10`)}
      data-pagefind-ignore={props.noIndex ? 'all' : undefined}
    >
      <slot />
    </main>
    <Footer hideCta={props.hideCta} />
    <Search />

    <script is:inline>
      const getTheme = () =>
        window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark'
          : 'light'

      const applyTheme = (element, theme) => {
        element.dataset.theme = theme
        element.dataset.pfTheme = theme
      }

      applyTheme(document.documentElement, getTheme())

      window
        .matchMedia('(prefers-color-scheme: dark)')
        .addEventListener('change', (event) => {
          applyTheme(document.documentElement, event.matches ? 'dark' : 'light')
        })

      document.addEventListener('astro:page-load', () => {
        applyTheme(document.documentElement, getTheme())
      })

      document.addEventListener('astro:before-swap', (event) => {
        applyTheme(event.newDocument.documentElement, getTheme())
      })

      const openSearchModal = async () => {
        try {
          await customElements.whenDefined('pagefind-modal')
        } catch (err) {
          console.warn('pagefind-modal registration failed', err)
          return
        }

        const modal = document.getElementById('site-search-modal')
        if (modal && typeof modal.open === 'function') {
          modal.open()
        } else {
          console.warn('pagefind-modal instance not ready', modal)
        }
      }

      document.addEventListener('keydown', (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
          event.preventDefault()
          openSearchModal()
        }
      })

      document.addEventListener('click', (event) => {
        const trigger = event.target?.closest?.('[data-search-trigger]')
        if (trigger) {
          event.preventDefault()
          openSearchModal()
        }
      })
    </script>
  </body>
</html>
