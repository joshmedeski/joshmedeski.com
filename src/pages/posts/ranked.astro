---
import { getCollection } from 'astro:content'
import Layout from '../../components/Layout.astro'
import PageTitle from '../../components/PageTitle.astro'
import Wrapper from '../../components/Wrapper.astro'
import RankedPosts from '../../components/RankedPosts.astro'
import { pageviewsFromRecord, rankPosts } from '../../utils/fathom'
import snapshot from '../../data/pageviews.json'

const includeDrafts = import.meta.env.DEV
const posts = await getCollection(
  'posts',
  ({ data: { draft } }) => includeDrafts || !draft,
)
const viewsByPathname = pageviewsFromRecord(snapshot.pageviews)
const ranked = rankPosts(posts, viewsByPathname)

const dateFormat = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'medium',
  timeZone: 'UTC',
})
const since = dateFormat.format(new Date(snapshot.since))
const updated = dateFormat.format(new Date(snapshot.fetchedAt))
---

<Layout title="Ranked Posts">
  <Wrapper>
    <PageTitle>Ranked Posts</PageTitle>
    <p class="-mt-8 mb-12 text-center text-sm text-neutral-500">
      Lifetime pageviews since {since} · Updated {updated}
    </p>
    <RankedPosts posts={ranked} />
  </Wrapper>
</Layout>
