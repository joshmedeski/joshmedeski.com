# build output
dist/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# netlify build files
.netlify
functions/.netlify
coverage
\n.astro
.astro

# Obsidian per-user / per-device state
content/.obsidian/workspace*
content/.obsidian/cache
content/.obsidian/graph.json

# Plugins and themes live in their own repos — ignore the code,
# keep the list files so the vault still declares what it wants.
content/.obsidian/plugins/
content/.obsidian/themes/
!content/.obsidian/community-plugins.json
!content/.obsidian/community-themes.json

# Stray .obsidian at repo root (in case the repo root is opened by accident)
/.obsidian/
